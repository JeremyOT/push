#!/bin/bash

# Default session name is current directory
SESSION_NAME=$(basename "$PWD")
RESUME=false
YOLO=false
SESSION_NAME_OVERRIDE=""
ADDITIONAL_ARGS=()

# Parse arguments
while [[ "$#" -gt 0 ]]; do
    case $1 in
        --resume) RESUME=true; shift ;;
        --yolo) YOLO=true; shift ;;
        *)
            if [ -z "$SESSION_NAME_OVERRIDE" ]; then
                SESSION_NAME_OVERRIDE="$1"
                SESSION_NAME="$1"
            else
                ADDITIONAL_ARGS+=("$1")
            fi
            shift
            ;;
    esac
done

# Prepare gemini args
GEMINI_ARGS=("${ADDITIONAL_ARGS[@]}")
if [ "$YOLO" = true ]; then
    GEMINI_ARGS=("-y" "${GEMINI_ARGS[@]}")
fi

# Determine Session ID
if [ "$RESUME" = true ]; then
    # Get the latest session ID from the list
    SESSION_ID=$(gemini --list-sessions | grep '\[.*\]' | tail -n 1 | sed -E 's/.*\[(.*)\].*/\1/')
    if [ -z "$SESSION_ID" ]; then
        echo "Warning: No session found to resume. Initializing new session..."
        RESUME=false
    else
        echo "Resuming session: $SESSION_ID"
    fi
fi

if [ "$RESUME" = false ]; then
    echo "Initializing new session..."
    # Start and exit immediately to create the session
    # We use --skip-trust to avoid interactive prompts
    echo "exit" | gemini --skip-trust > /dev/null 2>&1
    SESSION_ID=$(gemini --list-sessions | grep '\[.*\]' | tail -n 1 | sed -E 's/.*\[(.*)\].*/\1/')
    echo "Started session: $SESSION_ID"
fi

# Get current tmux pane ID
if [ -n "$TMUX" ]; then
    TMUX_TARGET=$(tmux display-message -p '#{pane_id}')
else
    echo "Error: gemini-agent must be run inside a tmux session."
    exit 1
fi

# Start push client in the background
PUSH_CMD="push"
if [ -f "./push" ]; then
    PUSH_CMD="./push"
fi

$PUSH_CMD --cli-service tmux \
    --session-id "$SESSION_ID" \
    --session-name "$SESSION_NAME" \
    --model gemini \
    --tmux-target "$TMUX_TARGET" &

PUSH_PID=$!

# Hook to terminate push client when gemini-cli exits
trap "kill $PUSH_PID 2>/dev/null" EXIT

# Start gemini-cli by resuming the established session
gemini --resume latest "${GEMINI_ARGS[@]}"

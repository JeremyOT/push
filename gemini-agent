#!/bin/bash

# Default session name is current directory
SESSION_NAME=$(basename "$PWD")
RESUME=false
YOLO=false
SESSION_NAME_OVERRIDE=""
ADDITIONAL_ARGS=()
AGENT_CMD="gemini"

# Parse arguments
while [[ "$#" -gt 0 ]]; do
    case $1 in
        --agent) AGENT_CMD="$2"; shift 2 ;;
        --resume|--continue) RESUME=true; shift ;;
        --yolo) YOLO=true; shift ;;
        *)
            if [ -z "$SESSION_NAME_OVERRIDE" ]; then
                SESSION_NAME_OVERRIDE="$1"
                SESSION_NAME="$1"
            else
                ADDITIONAL_ARGS+=("$1")
            fi
            shift
            ;;
    esac
done

# Prepare agent args
AGENT_ARGS=("${ADDITIONAL_ARGS[@]}")
if [ "$YOLO" = true ]; then
    if [ "$AGENT_CMD" = "agy" ]; then
        AGENT_ARGS=("--dangerously-skip-permissions" "${AGENT_ARGS[@]}")
    else
        AGENT_ARGS=("-y" "${AGENT_ARGS[@]}")
    fi
fi

# Get current tmux pane ID
if [ -n "$TMUX" ]; then
    TMUX_TARGET=$(tmux display-message -p '#{pane_id}')
else
    echo "Error: agent-launcher must be run inside a tmux session."
    exit 1
fi

PUSH_CMD="${PUSH_BINARY:-push}"
if [ -z "$PUSH_BINARY" ] && [ -f "./push" ]; then
    PUSH_CMD="./push"
fi

SESSION_PATH=$(pwd)
RESTART_FILE=".gemini-agent.restart"

# Ensure clean state
rm -f "$RESTART_FILE"

# Keep track of background processes for cleanup
SCRAPER_PID=""
PUSH_PID=""
PUSH_PID_FILE="/tmp/push-client-$$.pid"
AGY_LOG=""

cleanup() {
    if [ -n "$SCRAPER_PID" ]; then
        kill "$SCRAPER_PID" 2>/dev/null
        local count=0
        while kill -0 "$SCRAPER_PID" 2>/dev/null && [ $count -lt 10 ]; do
            sleep 0.1
            count=$((count + 1))
        done
        if kill -0 "$SCRAPER_PID" 2>/dev/null; then
            kill -9 "$SCRAPER_PID" 2>/dev/null
        fi
        wait "$SCRAPER_PID" 2>/dev/null
        SCRAPER_PID=""
    fi
    if [ -n "$PUSH_PID_FILE" ] && [ -f "$PUSH_PID_FILE" ]; then
        PID=$(cat "$PUSH_PID_FILE" 2>/dev/null)
        if [ -n "$PID" ]; then
            kill "$PID" 2>/dev/null
            local count=0
            while kill -0 "$PID" 2>/dev/null && [ $count -lt 10 ]; do
                sleep 0.1
                count=$((count + 1))
            done
            if kill -0 "$PID" 2>/dev/null; then
                kill -9 "$PID" 2>/dev/null
            fi
        fi
        rm -f "$PUSH_PID_FILE"
    fi
    if [ -n "$PUSH_PID" ]; then
        kill "$PUSH_PID" 2>/dev/null
        local count=0
        while kill -0 "$PUSH_PID" 2>/dev/null && [ $count -lt 10 ]; do
            sleep 0.1
            count=$((count + 1))
        done
        if kill -0 "$PUSH_PID" 2>/dev/null; then
            kill -9 "$PUSH_PID" 2>/dev/null
        fi
        wait "$PUSH_PID" 2>/dev/null
        PUSH_PID=""
    fi
    if [ -n "$AGY_LOG" ] && [ -f "$AGY_LOG" ]; then
        rm -f "$AGY_LOG"
        AGY_LOG=""
    fi
}
trap cleanup EXIT

while true; do
    # Determine Session ID
    if [ "$RESUME" = true ]; then
        if [ "$AGENT_CMD" = "agy" ]; then
            SESSION_ID="agy-pending"
        else
            SESSION_ID=$($AGENT_CMD --list-sessions | grep '\[.*\]' | tail -n 1 | sed -E 's/.*\[(.*)\].*/\1/')
        fi
        
        if [ -z "$SESSION_ID" ]; then
            echo "Warning: No session found to resume. Initializing new session..."
            RESUME=false
        else
            if [ "$AGENT_CMD" != "agy" ]; then
                echo "Resuming session: $SESSION_ID"
            fi
        fi
    fi

    if [ "$RESUME" = false ]; then
        if [ "$AGENT_CMD" = "agy" ]; then
            UUID=$(uuidgen 2>/dev/null)
            if [ -z "$UUID" ]; then
                UUID=$(python3 -c "import uuid; print(uuid.uuid4())")
            fi
            SESSION_ID="$UUID"
            echo "Started session: $SESSION_ID"
        else
            echo "Initializing new session..."
            # Start and exit immediately to create the session
            echo "/quit" | $AGENT_CMD --skip-trust > /dev/null 2>&1
            SESSION_ID=$($AGENT_CMD --list-sessions | grep '\[.*\]' | tail -n 1 | sed -E 's/.*\[(.*)\].*/\1/')
            echo "Started session: $SESSION_ID"
        fi
    fi

    # Start push client in the background (for non-agy, and for agy fresh sessions at startup)
    if [ "$AGENT_CMD" != "agy" ] || [ "$RESUME" = false ]; then
        $PUSH_CMD --cli-service tmux \
            --session-id "$SESSION_ID" \
            --session-name "$SESSION_NAME" \
            --session-path "$SESSION_PATH" \
            --model "$AGENT_CMD" \
            --tmux-target "$TMUX_TARGET" &
        if [ "$AGENT_CMD" = "agy" ]; then
            echo $! > "$PUSH_PID_FILE"
        else
            PUSH_PID=$!
        fi
    fi

    # Antigravity log scraper integration
    SCRAPER_PID=""
    CURRENT_AGENT_ARGS=("${AGENT_ARGS[@]}")
    if [ "$AGENT_CMD" = "agy" ]; then
        UUID=$(uuidgen 2>/dev/null)
        if [ -z "$UUID" ]; then
            UUID=$(python3 -c "import uuid; print(uuid.uuid4())")
        fi
        AGY_LOG="/tmp/agy-$UUID.log"
        touch "$AGY_LOG"
        
        # Start a discovery background process
        (
            CONV_ID=""
            APP_DATA_DIR=""
            while [ -z "$CONV_ID" ] || [ -z "$APP_DATA_DIR" ]; do
                if [ -f "$AGY_LOG" ]; then
                    CONV_ID=$(grep -m 1 "Streaming conversation" "$AGY_LOG" | awk '{print $NF}')
                    APP_DATA_DIR=$(grep -m 1 "Creating CLI server backend:" "$AGY_LOG" | sed -n 's/.*appDataDir=\([^ ]*\).*/\1/p')
                fi
                if [ -z "$CONV_ID" ] || [ -z "$APP_DATA_DIR" ]; then
                    sleep 0.5
                fi
            done

            if [ "$RESUME" = true ]; then
                echo "Resuming session: $CONV_ID"

                # Start push client in the background now that we have the session/conversation ID
                $PUSH_CMD --cli-service tmux \
                    --session-id "$CONV_ID" \
                    --session-name "$SESSION_NAME" \
                    --session-path "$SESSION_PATH" \
                    --model "$AGENT_CMD" \
                    --tmux-target "$TMUX_TARGET" &
                echo $! > "$PUSH_PID_FILE"
            else
                echo "Started session: $CONV_ID"
                
                # Kill the old startup push client first to allow its exit status to be sent before renaming
                PID=$(cat "$PUSH_PID_FILE" 2>/dev/null)
                if [ -n "$PID" ]; then
                    kill "$PID" 2>/dev/null
                    local count=0
                    while kill -0 "$PID" 2>/dev/null && [ $count -lt 10 ]; do
                        sleep 0.1
                        count=$((count + 1))
                    done
                    if kill -0 "$PID" 2>/dev/null; then
                        kill -9 "$PID" 2>/dev/null
                    fi
                fi
                rm -f "$PUSH_PID_FILE"

                # Rename the session ID in the database from the temporary UUID to the conversation ID
                curl -s -X POST "http://${PUSH_ADDRESS:-127.0.0.1:8089}/rename-session?old=$SESSION_ID&new=$CONV_ID" >/dev/null

                # Start the new push client with the correct conversation ID
                $PUSH_CMD --cli-service tmux \
                    --session-id "$CONV_ID" \
                    --session-name "$SESSION_NAME" \
                    --session-path "$SESSION_PATH" \
                    --model "$AGENT_CMD" \
                    --tmux-target "$TMUX_TARGET" &
                echo $! > "$PUSH_PID_FILE"
            fi

            LOG_FILE="$APP_DATA_DIR/brain/$CONV_ID/.system_generated/logs/transcript_full.jsonl"
            echo "Started internal agy log scraper for $LOG_FILE"

            # Now start the real scraper
            YOLO_FLAG=""
            if [ "$YOLO" = true ]; then
                YOLO_FLAG="--yolo"
            fi
            exec $PUSH_CMD --internal-agy-scraper \
                --agy-log-file "$LOG_FILE" \
                --agy-backend-url "http://${PUSH_ADDRESS:-127.0.0.1:8089}" \
                --agy-fallback-session-id "$CONV_ID" \
                --agy-session-path "$SESSION_PATH" \
                --tmux-target "$TMUX_TARGET" \
                $YOLO_FLAG
        ) &
        SCRAPER_PID=$!

        CURRENT_AGENT_ARGS=("--log-file" "$AGY_LOG" "${CURRENT_AGENT_ARGS[@]}")
    fi

    # Start the agent
    if [ "$AGENT_CMD" = "agy" ]; then
        if [ "$RESUME" = true ]; then
            $AGENT_CMD --continue "${CURRENT_AGENT_ARGS[@]}"
        else
            $AGENT_CMD "${CURRENT_AGENT_ARGS[@]}"
        fi
    else
        gemini --resume latest "${CURRENT_AGENT_ARGS[@]}"
    fi
    EXIT_CODE=$?

    # Cleanup
    cleanup
    
    # Handle restart requests
    if [ -f "$RESTART_FILE" ]; then
        MODE=$(cat "$RESTART_FILE")
        rm -f "$RESTART_FILE"
        if [ "$MODE" = "resume" ]; then
            echo "Restarting and resuming session..."
            RESUME=true
        else
            echo "Restarting fresh..."
            RESUME=false
        fi
        continue
    fi

    # Normal exit
    exit $EXIT_CODE
done

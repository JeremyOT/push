#!/bin/bash

# Default session name is current directory
SESSION_NAME=$(basename "$PWD")
RESUME=false
SESSION_NAME_OVERRIDE=""
ADDITIONAL_ARGS=()

# Parse arguments
while [[ "$#" -gt 0 ]]; do
    case $1 in
        --resume) RESUME=true; shift ;;
        *)
            if [ -z "$SESSION_NAME_OVERRIDE" ]; then
                SESSION_NAME_OVERRIDE="$1"
                SESSION_NAME="$1"
            else
                ADDITIONAL_ARGS+=("$1")
            fi
            shift
            ;;
    esac
done

# Determine Session ID
if [ "$RESUME" = true ]; then
    # Get the latest session ID from the list
    SESSION_ID=$(/opt/homebrew/bin/gemini --list-sessions | grep '\[.*\]' | tail -n 1 | sed -E 's/.*\[(.*)\].*/\1/')
    if [ -z "$SESSION_ID" ]; then
        echo "Warning: No session found to resume. Generating new session ID."
        SESSION_ID=$(uuidgen | tr '[:upper:]' '[:lower:]')
        RESUME=false
    else
        echo "Resuming session: $SESSION_ID"
    fi
else
    # Generate a new session ID
    SESSION_ID=$(uuidgen | tr '[:upper:]' '[:lower:]')
fi

# Get current tmux pane ID
if [ -n "$TMUX" ]; then
    TMUX_TARGET=$(tmux display-message -p '#{pane_id}')
else
    echo "Error: gemini-agent must be run inside a tmux session."
    exit 1
fi

# Start push client in the background
# Using the binary found at /Users/jeremyot/bin/push
/Users/jeremyot/bin/push --cli-service tmux \
    --session-id "$SESSION_ID" \
    --session-name "$SESSION_NAME" \
    --model gemini \
    --tmux-target "$TMUX_TARGET" &

PUSH_PID=$!

# Hook to terminate push client when gemini-cli exits
trap "kill $PUSH_PID 2>/dev/null" EXIT

# Start gemini-cli with the session ID
# GEMINI_SESSION_ID environment variable is used to set the session ID
export GEMINI_SESSION_ID="$SESSION_ID"

if [ "$RESUME" = true ]; then
    /opt/homebrew/bin/gemini --resume latest "${ADDITIONAL_ARGS[@]}"
else
    /opt/homebrew/bin/gemini "${ADDITIONAL_ARGS[@]}"
fi
